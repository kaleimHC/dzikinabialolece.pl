[bandit]
# B101 — assert statements: valid in test code, not a production risk here
# B601 — paramiko shell injection: paramiko is not used in this project
# B608 — SQL injection: flagged in sql_injection_patch.py which contains
#         the allowlist validators themselves (not injection sites)
skips = B101,B601,B608

# Only scan production application code; exclude test directories
exclude = src/analytics/tests,src/tests,tests
