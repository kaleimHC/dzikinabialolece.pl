# =============================================================================
# Environment Variables - Dziki na Białołęce
# =============================================================================
# Copy to .env and customize for your environment
# NEVER commit .env to git (only .env.example)
# =============================================================================

# Database
DB_PASSWORD=<CHANGE_ME_strong_password>

# Redis
REDIS_PASSWORD=<CHANGE_ME_strong_password>

# Django
DEBUG=False
SECRET_KEY=<CHANGE_ME_use_django_secret_key_generator>
IP_HASH_SECRET=<CHANGE_ME_random_32_char_string>

# =============================================================================
# Production checklist:
# [ ] DB_PASSWORD - strong, unique, from secrets manager
# [ ] REDIS_PASSWORD - strong, unique
# [ ] SECRET_KEY - generated with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# [ ] DEBUG=False
# =============================================================================
